    "version": "0.2.0",
    "configurations": [
        {
            "name": "Test TivoDecoder",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/pkg/tivolibre/decoder_test.go",
            "args": [
                "-timeout",
                "2m",
                "-test.run",
                "TestDecoder"
            ],
            "envFile": "${workspaceFolder}/vscode.env",
        },
        {
            "name": "Launch KMTTG",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "envFile": "${workspaceFolder}/vscode.env",
        }
    ]
}